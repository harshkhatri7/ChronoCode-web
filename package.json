{
  "name": "chronocode-desktop",
  "version": "3.0.0-beta.1",
  "description": "ChronoCode — Automatic Code Versioning Desktop App",
  "main": "electron-main.js",
  "author": "Harsh Khatri",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env ELECTRON_DEV=1 electron .",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.chronocode.desktop",
    "productName": "ChronoCode",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "db.js",
      "assets/**/*",
      "public/**/*",
      "*.html",
      ".env"
    ],
    "extraResources": [],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ChronoCode"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/logo.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/logo.png",
      "category": "Development"
    }
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongodb": "^6.8.0",
    "serverless-http": "^3.2.0",
    "ws": "^8.17.1"
  }
}
